<h1>Tu carrito</h1>

{{#if cart.products.length}}

  <table border="1" cellpadding="10">

    <thead>
      <tr>
        <th>Producto</th>
        <th>Precio</th>
        <th>Cantidad</th>
        <th>Subtotal</th>
        <th>Acción</th>
      </tr>
    </thead>

    <tbody>

      {{#each cart.products}}
        <tr>

          <td>{{this.product.title}}</td>

          <td>${{this.product.price}}</td>

          <td>{{this.quantity}}</td>

          <td>
            ${{this.subtotal}}
          </td>

          <td>
            <button
              class="btn-remove-product"
              data-product="{{this.product._id}}"
            >
              Quitar
            </button>
          </td>

        </tr>
      {{/each}}

    </tbody>

  </table>

  <br />

  <h3>Total: ${{cart.total}}</h3>

  <br />

  <button id="btn-clear-cart">
    Vaciar carrito
  </button>

  <button id="btn-purchase">
    Finalizar compra
  </button>

{{else}}

  <p>El carrito está vacío</p>

{{/if}}

<script src="/js/cartView.js"></script>