<div>
  <h1>Home</h1>

  {{#each products}}

    <div>
      <h2>{{this.title}}</h2>
      <p>Price: {{this.price}}</p>
      <a href="/detail/{{this._id}}">
        <button>Ver detalles</button>
      </a>
    </div>

  {{/each}}

  {{#each links}}
    <a href="{{this.link}}">{{this.number}}</a>
  {{/each}}

</div>